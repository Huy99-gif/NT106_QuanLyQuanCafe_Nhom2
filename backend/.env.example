PORT=3000

# Firebase Realtime Database
FIREBASE_DATABASE_URL=Điền URL của Firebase Realtime Database vào đây

# Firebase Web API Key (dùng cho signInWithPassword)
FIREBASE_API_KEY="Điền Firebase Web API Key vào đây"

# Secret key bảo vệ endpoint đổi mật khẩu
APP_SECRET_KEY="Điền secret key vào đây"

# Gmail App Password (bật 2FA rồi tạo App Password)
EMAIL_USER="Điền email của bạn vào đây"
EMAIL_PASS="Điền Gmail App Password vào đây"

# Môi trường (development | production)
NODE_ENV=development